{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://decryptvoid-visionova.hf.space/api/$1"
        },
        {
            "source": "/css/(.*)",
            "destination": "/frontend/css/$1"
        },
        {
            "source": "/js/(.*)",
            "destination": "/frontend/js/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/html/$1"
        }
    ],
    "cleanUrls": true
}